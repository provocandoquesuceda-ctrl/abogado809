import Link from 'next/link'
import Image from 'next/image'
import { MapPin, Star, CheckCircle, MessageCircle, Phone } from 'lucide-react'
import { formatCiudad, formatWhatsApp } from '@/lib/utils'

type AbogadoCardProps = {
  slug: string
  foto?: string | null
  titulo: string
  nombre: string
  apellidos: string
  ciudad: string
  verificado: boolean
  descripcion: string
  especialidades: { nombre: string; slug: string }[]
  resenas: { rating: number }[]
  whatsapp?: string | null
}

export default function AbogadoCard({
  slug, foto, titulo, nombre, apellidos, ciudad,
  verificado, descripcion, especialidades, resenas, whatsapp,
}: AbogadoCardProps) {
  const nombreCompleto = `${titulo} ${nombre} ${apellidos}`
  const rating = resenas.length
    ? Math.round((resenas.reduce((a, r) => a + r.rating, 0) / resenas.length) * 10) / 10
    : null

  return (
    <div className="card group hover:shadow-dorado hover:-translate-y-1 transition-all duration-300">
      <div className="p-6">
        <div className="flex gap-4">
          {/* Foto */}
          <div className="relative flex-shrink-0">
            <div className="w-20 h-20 rounded-full overflow-hidden bg-marino/10 border-2 border-marino/10">
              {foto ? (
                <Image src={foto} alt={nombreCompleto} width={80} height={80} className="object-cover w-full h-full" />
              ) : (
                <div className="w-full h-full flex items-center justify-center bg-marino/10">
                  <span className="text-2xl font-display font-bold text-marino/40">
                    {nombre[0]}{apellidos[0]}
                  </span>
                </div>
              )}
            </div>
            {verificado && (
              <div className="absolute -bottom-1 -right-1 bg-green-500 rounded-full p-0.5 border-2 border-white">
                <CheckCircle className="w-3 h-3 text-white fill-white" />
              </div>
            )}
          </div>

          {/* Info */}
          <div className="flex-1 min-w-0">
            <div className="flex items-start justify-between gap-2">
              <div>
                <h3 className="font-display font-semibold text-marino text-lg leading-tight">
                  {nombreCompleto}
                </h3>
                <div className="flex items-center gap-1.5 mt-1">
                  <MapPin className="w-3.5 h-3.5 text-gray-400 flex-shrink-0" />
                  <span className="text-gray-500 text-sm">{formatCiudad(ciudad)}</span>
                </div>
              </div>
              {rating && (
                <div className="flex items-center gap-1 flex-shrink-0">
                  <Star className="w-4 h-4 text-dorado fill-dorado" />
                  <span className="font-semibold text-sm text-gray-700">{rating}</span>
                  <span className="text-gray-400 text-xs">({resenas.length})</span>
                </div>
              )}
            </div>

            {/* Especialidades */}
            <div className="flex flex-wrap gap-1.5 mt-3">
              {especialidades.slice(0, 3).map(e => (
                <span key={e.slug} className="badge-especialidad">{e.nombre}</span>
              ))}
              {especialidades.length > 3 && (
                <span className="badge-especialidad">+{especialidades.length - 3}</span>
              )}
            </div>
          </div>
        </div>

        {/* Descripción */}
        <p className="text-gray-500 text-sm mt-4 line-clamp-2 leading-relaxed">
          {descripcion}
        </p>
      </div>

      {/* Acciones */}
      <div className="px-6 py-4 bg-gray-50 border-t border-gray-100 flex items-center justify-between gap-3">
        <Link href={`/abogado/${slug}`}
          className="btn-primary text-sm py-2 px-4 flex-1 justify-center">
          Ver perfil completo
        </Link>
        {whatsapp && (
          <a href={formatWhatsApp(whatsapp, nombreCompleto)}
            target="_blank" rel="noopener noreferrer"
            className="flex items-center gap-1.5 bg-green-500 hover:bg-green-600 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors">
            <MessageCircle className="w-4 h-4" />
            WhatsApp
          </a>
        )}
      </div>
    </div>
  )
}
