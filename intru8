  return (
    <header className="sticky top-0 z-50 bg-marino shadow-md">
      <nav className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div className="flex items-center justify-between h-16">

          {/* Logo */}
          <Link href="/" className="flex items-center gap-2 group">
            <div className="bg-dorado p-1.5 rounded-lg">
              <Scale className="w-5 h-5 text-marino" />
            </div>
            <span className="font-display text-xl font-bold text-white">
              Abogado<span className="text-dorado">809</span>
            </span>
          </Link>

          {/* Desktop links */}
          <div className="hidden md:flex items-center gap-6">
            <Link href="/buscar" className="text-white/80 hover:text-dorado text-sm font-medium transition-colors">
              Buscar abogado
            </Link>
            <Link href="/buscar?especialidad=penal" className="text-white/80 hover:text-dorado text-sm font-medium transition-colors">
              Áreas del derecho
            </Link>

            {session ? (
              <div className="flex items-center gap-3">
                <Link href="/dashboard"
                  className="flex items-center gap-1.5 text-white/80 hover:text-dorado text-sm font-medium transition-colors">
                  <LayoutDashboard className="w-4 h-4" />
                  Mi panel
                </Link>
                <button
                  onClick={() => signOut({ callbackUrl: '/' })}
                  className="flex items-center gap-1.5 text-white/60 hover:text-red-400 text-sm transition-colors"
                >
                  <LogOut className="w-4 h-4" />
                  Salir
                </button>
              </div>
            ) : (
              <div className="flex items-center gap-3">
                <Link href="/login"
                  className="text-white/80 hover:text-white text-sm font-medium transition-colors">
                  Iniciar sesión
                </Link>
                <Link href="/registro"
                  className="bg-dorado text-marino text-sm font-semibold px-4 py-2 rounded-lg hover:bg-dorado-light transition-colors">
                  Registrar mi bufete
                </Link>
              </div>
            )}
          </div>

          {/* Mobile toggle */}
          <button onClick={() => setOpen(!open)} className="md:hidden text-white p-2">
            {open ? <X className="w-6 h-6" /> : <Menu className="w-6 h-6" />}
          </button>
        </div>

        {/* Mobile menu */}
        {open && (
          <div className="md:hidden py-4 border-t border-white/10 space-y-2">
            <Link href="/buscar" onClick={() => setOpen(false)}
              className="block text-white/80 hover:text-dorado py-2 text-sm font-medium">
              Buscar abogado
            </Link>
            {session ? (
              <>
                <Link href="/dashboard" onClick={() => setOpen(false)}
                  className="block text-white/80 hover:text-dorado py-2 text-sm font-medium">
                  Mi panel
                </Link>
                <button onClick={() => signOut({ callbackUrl: '/' })}
                  className="block text-white/60 hover:text-red-400 py-2 text-sm w-full text-left">
                  Cerrar sesión
                </button>
              </>
            ) : (
              <>
                <Link href="/login" onClick={() => setOpen(false)}
                  className="block text-white/80 hover:text-dorado py-2 text-sm">
                  Iniciar sesión
                </Link>
                <Link href="/registro" onClick={() => setOpen(false)}
                  className="block bg-dorado text-marino text-sm font-semibold px-4 py-2 rounded-lg text-center mt-2">
                  Registrar mi bufete
                </Link>
              </>
            )}
